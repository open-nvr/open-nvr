# ====================================================================
# Frontend Environment Variables (OPTIONAL)
# ====================================================================
#
# This file is OPTIONAL for standard setups!
#
# Default behavior (no .env file needed):
# - Development: Uses Vite proxy to http://localhost:8000
# - Production: Uses window.location.origin (same as frontend)
#
# Only create app/.env if you need to override the backend URL:
# - Backend runs on non-standard port (not 8000)
# - Backend runs on different host
#
# Example: If backend runs on port 9000:
# VITE_API_BASE_URL=http://localhost:9000
#
# ====================================================================

# Backend API base URL (optional override)
# VITE_API_BASE_URL=http://localhost:8000

