# ============================================================
# OpenNVR - Server Local Development Configuration
# ============================================================
#
# This file is for LOCAL (non-Docker) development only.
# For Docker deployment, use the root .env file instead.
#
# Setup:
#   1. Copy this file:  cp server/.env.example server/.env
#   2. Fill in secrets: ./scripts/generate-secrets.sh (or .ps1)
#   3. Start services manually (PostgreSQL + MediaMTX must be running locally)
#
# ============================================================

# ============================================================
# DATABASE
# ============================================================
# Local PostgreSQL instance
DATABASE_URL=postgresql://opennvr_user:CHANGE_THIS_PASSWORD@localhost:5432/opennvr_db

# ============================================================
# SECURITY & AUTHENTICATION
# ============================================================
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=30

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: Never change this after first run — all camera passwords will become unreadable!
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_GENERATE_FERNET_KEY

# Generate with: openssl rand -base64 32
# Must match kai-c/.env INTERNAL_API_KEY
INTERNAL_API_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32

# Generate with: openssl rand -hex 32
# Must match the secret in mediamtx.local.yml webhooks
MEDIAMTX_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ============================================================
# APPLICATION SETTINGS
# ============================================================
DEBUG=True
HOST=127.0.0.1
PORT=8000
APPLICATION_URL=http://localhost:8000
API_PREFIX=/api/v1

# ============================================================
# MEDIAMTX (local instance — all localhost)
# ============================================================
MEDIAMTX_BASE_URL=http://127.0.0.1:8889
MEDIAMTX_ADMIN_API=http://127.0.0.1:9997/v3
MEDIAMTX_API_URL=http://127.0.0.1:9997
MEDIAMTX_HLS_URL=http://127.0.0.1:8888
MEDIAMTX_RTSP_URL=rtsp://127.0.0.1:8554
MEDIAMTX_PLAYBACK_URL=http://127.0.0.1:9996
MEDIAMTX_STREAM_PREFIX=cam-
MEDIAMTX_PATH_MODE=id
MEDIAMTX_AUTO_PROVISION=True

# ============================================================
# RECORDING SETTINGS
# ============================================================
# Use an absolute path appropriate for your OS:
#   Linux/macOS: /var/lib/opennvr/recordings
#   Windows:     C:/opennvr/recordings
RECORDINGS_BASE_PATH=/var/lib/opennvr/recordings

# ============================================================
# KAI-C AI ORCHESTRATOR
# ============================================================
KAI_C_URL=http://127.0.0.1:8100
KAI_C_IP=127.0.0.1

# ============================================================
# DEFAULT ADMIN USER (created on first startup)
# ============================================================
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_FIRST_NAME=System
DEFAULT_ADMIN_LAST_NAME=Administrator

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=DEBUG
LOG_FILE_ENABLED=True
LOG_FILE_PATH=logs/server.log
LOG_FILE_MAX_SIZE_MB=50
LOG_FILE_BACKUP_COUNT=10
LOG_CONSOLE_ENABLED=True
LOG_JSON_FORMAT=False
