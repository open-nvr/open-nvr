# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/kavach

# JWT Configuration
SECRET_KEY=change-this-secret-key-to-something-secure
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Application Configuration
DEBUG=True
HOST=127.0.0.1
PORT=8000
APPLICATION_URL=http://localhost:8000
API_PREFIX=/api/v1

# MediaMTX Configuration (all localhost-only for security)
MEDIAMTX_BASE_URL=http://127.0.0.1:8889
MEDIAMTX_STREAM_PREFIX=cam-
MEDIAMTX_PATH_MODE=id
MEDIAMTX_AUTO_PROVISION=True

# MediaMTX Admin API v3
MEDIAMTX_ADMIN_API=http://127.0.0.1:9997/v3

# MediaMTX Service URLs
MEDIAMTX_HLS_URL=http://127.0.0.1:8888
MEDIAMTX_RTSP_URL=rtsp://127.0.0.1:8554
MEDIAMTX_PLAYBACK_URL=http://127.0.0.1:9996

# MediaMTX Security Secret - CRITICAL FOR LOCAL DEVELOPMENT!
# This secret is used for webhook authentication between MediaMTX and the backend.
# MUST match the X-MTX-Secret parameter in mediamtx.yml webhooks (runOnInit, runOnRecordSegmentComplete)
# Generate with: openssl rand -hex 32
# IMPORTANT: If you change this, you MUST also update mediamtx.yml webhook URLs!
MEDIAMTX_SECRET=your-secret-here-generate-with-openssl-rand-hex-32

# Recording Settings
# Use absolute path (e.g. /var/lib/opennvr/recordings or C:/opennvr/recordings)
RECORDINGS_BASE_PATH=./recordings

# Default Admin User (created on startup if not exists)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_FIRST_NAME=System
DEFAULT_ADMIN_LAST_NAME=Administrator

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE_ENABLED=True
LOG_FILE_PATH=logs/server.log
LOG_FILE_MAX_SIZE_MB=50
LOG_FILE_BACKUP_COUNT=10
LOG_CONSOLE_ENABLED=True
LOG_JSON_FORMAT=True

# =============================================================================
# Cloud Provider Configuration (for cloud AI inference)
# =============================================================================
# Fernet encryption key for credential storage
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# Internal API key for authentication between opennvr and kai-c
INTERNAL_API_KEY=change-this-internal-api-key

# KAI-C orchestrator URL
# Local development: http://localhost:8100
# Docker deployment: http://ai-adapters:9100
KAI_C_URL=http://localhost:8100

# KAI-C IP for whitelisting
KAI_C_IP=127.0.0.1