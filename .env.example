# ============================================================
# OpenNVR - Environment Configuration
# ============================================================
#
# QUICK START (Docker):
#   1. Copy this file:  cp .env.example .env   (Linux/macOS)
#                       copy .env.example .env  (Windows)
#   2. Generate real secrets (for production):
#        Linux/macOS:  ./scripts/generate-secrets.sh --write
#        Windows:      .\scripts\generate-secrets.ps1 -Write
#   3. Set RECORDINGS_PATH to your storage location (see below)
#   4. Run: ./start.sh   (Linux/macOS)  or  .\start.ps1  (Windows)
#
# SECURITY WARNING:
#   The default secrets below are for LOCAL DEVELOPMENT only.
#   Run the secrets generator before any internet-facing deployment!
#   Never commit your .env file — it is already in .gitignore.
#
# ============================================================

# ============================================================
# DATABASE
# ============================================================
POSTGRES_USER=opennvr_user
# ⚠ CHANGE FOR PRODUCTION: generate with ./scripts/generate-secrets.sh --write
POSTGRES_PASSWORD=dev_postgres_pass_2024
POSTGRES_DB=opennvr_db

# ============================================================
# SECURITY & AUTHENTICATION
# ============================================================

# JWT signing key — min 32 characters
# ⚠ CHANGE FOR PRODUCTION: openssl rand -hex 32
SECRET_KEY=dev_jwt_secret_key_f8a4b2c9e1d7a5f3b8c4e2a9d6f1b7c3

# JWT algorithm (leave as HS256)
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Fernet key for encrypting camera credentials in the database
# ⚠ CHANGE FOR PRODUCTION: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CRITICAL: Never change this after first run — all stored camera passwords become unreadable!
CREDENTIAL_ENCRYPTION_KEY=CKLghtP4rWz8J9vN2xQ5mT7yU8kF6bD3eH1aG4cS0wE=

# Internal service-to-service API key (shared between backend and Kai-C)
# ⚠ CHANGE FOR PRODUCTION: openssl rand -base64 32
INTERNAL_API_KEY=dev_internal_api_key_h9j2k5l8m3n6p1q4

# MediaMTX webhook authentication secret
# ⚠ CHANGE FOR PRODUCTION: openssl rand -hex 32
MEDIAMTX_SECRET=dev_mediamtx_webhook_secret_x7y2z5a8b3c6d1e4

# ============================================================
# APPLICATION SETTINGS
# ============================================================
# Set to False in all production / internet-facing deployments
DEBUG=False
HOST=0.0.0.0
PORT=8000
APPLICATION_URL=http://localhost:8000
API_PREFIX=/api/v1

# ============================================================
# MEDIAMTX STREAMING SERVER
# ============================================================
# These are the URLs the backend uses to talk to MediaMTX.
# For Docker (bridge mode) these are overridden by docker-compose.yml.
# For local development they point to localhost.
MEDIAMTX_BASE_URL=http://localhost:8889
MEDIAMTX_ADMIN_API=http://localhost:9997/v3
MEDIAMTX_API_URL=http://localhost:9997
MEDIAMTX_HLS_URL=http://localhost:8888
MEDIAMTX_RTSP_URL=rtsp://localhost:8554
MEDIAMTX_PLAYBACK_URL=http://localhost:9996
MEDIAMTX_STREAM_PREFIX=cam-
MEDIAMTX_PATH_MODE=id
MEDIAMTX_AUTO_PROVISION=True

# ============================================================
# DOCKER SERVICE NETWORKING
# ============================================================
# Backend container name (used by MediaMTX to call webhook endpoints)
BACKEND_HOST=opennvr_core
BACKEND_PORT=8000

# ============================================================
# RECORDING STORAGE
# ============================================================
# Path on the HOST machine where recordings are stored.
# Docker mounts this path into both mediamtx and opennvr-core containers.
#
# Examples:
#   Linux:   RECORDINGS_PATH=/var/lib/opennvr/recordings
#   macOS:   RECORDINGS_PATH=/Users/Shared/opennvr-recordings
#   Windows: RECORDINGS_PATH=C:/opennvr/recordings
#
# The directory will be created automatically if it does not exist.
RECORDINGS_PATH=./recordings

# ============================================================
# AI INFERENCE (KAI-C + AI Adapters)
# ============================================================
# Set to true only if you have cloned the ai-adapter repo to ../ai-adapter
# and want the AI detection service to run.
# The installer sets this automatically.
AI_ENABLED=false

# Kai-C runs inside the opennvr-core container on port 8100.
# In Docker bridge mode 127.0.0.1 inside the container = itself (correct).
KAI_C_URL=http://127.0.0.1:8100
KAI_C_IP=127.0.0.1

# URL of the external AI Adapters service (opennvr_ai container).
# Only needed if you have cloned and enabled the ai-adapters service.
# Bridge mode (Windows/macOS):  ADAPTER_URL=http://opennvr_ai:9100
# Host mode   (Linux):           ADAPTER_URL=http://127.0.0.1:9100
# AI disabled (default):         leave commented out — docker-compose uses its own default
# ADAPTER_URL=

# ============================================================
# DEFAULT ADMIN USER
# ============================================================
# Created automatically on first startup if the user does not exist.
# ⚠ CHANGE the password before exposing the service on a network!
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=SecurePass123!
DEFAULT_ADMIN_EMAIL=admin@opennvr.local
DEFAULT_ADMIN_FIRST_NAME=System
DEFAULT_ADMIN_LAST_NAME=Administrator

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
LOG_FILE_ENABLED=True
LOG_FILE_PATH=logs/server.log
LOG_FILE_MAX_SIZE_MB=50
LOG_FILE_BACKUP_COUNT=10
LOG_CONSOLE_ENABLED=True
LOG_JSON_FORMAT=False
